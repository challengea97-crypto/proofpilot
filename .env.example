# --- Supabase (auth + database) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (billing) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- AI (Groq) ---
# Powers Live AI Research and the analysis modules. Get a key at console.groq.com.
GROQ_API_KEY=
# Optional model override (defaults to llama-3.3-70b-versatile).
GROQ_MODEL=

# --- Site ---
# Absolute base URL of the deployment. Locally this is http://localhost:3000.
# On Netlify set this to your live URL, e.g. https://teckro.netlify.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Scheduled watchlist monitoring (optional) ---
# Shared secret that guards /api/cron/monitor. Set the same value in Netlify so
# the daily scheduled function (netlify/functions/monitor.mts) can trigger it.
CRON_SECRET=

# --- Admin (optional) ---
# Comma-separated emails that can access /dashboard/admin.
ADMIN_EMAILS=
