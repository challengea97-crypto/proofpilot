# --- Supabase (auth + database) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (billing) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- AI research engine (Phase 2) ---
# Anthropic API key used for Live AI Research. Without it, research features
# show a clear "setup needed" state instead of fake output.
ANTHROPIC_API_KEY=
# Optional: override the model (defaults to claude-opus-4-8). Set this to a
# model your key can access if needed, e.g. claude-sonnet-4-5.
ANTHROPIC_MODEL=

# --- Site ---
# Absolute base URL of the deployment. Locally this is http://localhost:3000.
# On Netlify set this to your live URL, e.g. https://teckro.netlify.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
